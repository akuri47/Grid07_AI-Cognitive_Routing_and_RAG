# ─────────────────────────────────────────────────────────────────────────────
# Grid07 Environment Variables — COPY THIS FILE TO .env AND FILL IN YOUR KEYS
# DO NOT COMMIT YOUR ACTUAL .env FILE TO GIT
# ─────────────────────────────────────────────────────────────────────────────

# LLM Provider (choose one)
# Groq (recommended — free tier, fast Llama-3)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# Ollama (local, no key needed — set base URL if not default)
# OLLAMA_BASE_URL=http://localhost:11434
